{
  "name": "server",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -n \"WRANGLER,DRIZZLE-KIT\" -c \"blue,green\" \"wrangler dev --env development --ip 0.0.0.0 --log-level debug > wrangler_debug.log 2>&1\" \"drizzle-kit studio\"",
    "start": "wrangler deploy --env production",
    "build": "esbuild src/index.js --bundle --outfile=dist/index.js --platform=node --format=esm",
    "serve": "node server.js",
    "generate:migration": "drizzle-kit generate --schema src/db/schema.ts --dialect sqlite",
    "push:migration": "drizzle-kit push --db ./drizzle/sqlite.db",
    "sync:once": "node scripts/sync.mjs",
    "sync:incremental": "node scripts/sync.mjs",
    "sync:r2": "node scripts/sync_r2.mjs"
  },
  "dependencies": {
    "@andresaya/edge-tts": "^1.8.0",
    "@libsql/client": "^0.17.2",
    "@tsndr/cloudflare-worker-jwt": "^3.2.1",
    "cookie": "^1.1.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "djwt": "^2.0.0",
    "dotenv": "^17.3.1",
    "hono": "^4.12.9",
    "jimp": "^0.22.12",
    "jsonrepair": "^3.13.3",
    "langs": "^2.0.0",
    "mariadb": "^3.5.2",
    "nanoid": "^5.1.7",
    "undici": "^7.24.6"
  },
  "devDependencies": {
    "@cloudflare/puppeteer": "^1.0.6",
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.5.0",
    "better-sqlite3": "^12.8.0",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.1",
    "esbuild": "^0.27.4",
    "sharp": "^0.33.5",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "wrangler": "^4.77.0"
  }
}
