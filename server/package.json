{
  "name": "server",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -n \"WRANGLER,DRIZZLE-KIT\" -c \"blue,green\" \"wrangler dev --env development --ip 0.0.0.0 --port 8787 --log-level debug > wrangler_debug.log 2>&1\" \"drizzle-kit studio\"",
    "start": "wrangler deploy --env production",
    "build": "esbuild src/index.js --bundle --outfile=dist/index.js --platform=node --format=esm",
    "serve": "node server.js",
    "generate:migration": "drizzle-kit generate --schema src/db/schema.ts --dialect sqlite",
    "push:migration": "drizzle-kit push --db ./drizzle/sqlite.db",
    "sync:once": "node scripts/sync.mjs",
    "sync:images": "node scripts/sync_new_images.mjs",
    "sync:audios": "node scripts/sync_new_audios.mjs",
    "sync:incremental": "node scripts/sync.mjs",
    "sync:r2": "node scripts/sync_r2.mjs"
  },
  "dependencies": {
    "@andresaya/edge-tts": "^1.8.0",
    "@libsql/client": "^0.17.2",
    "@tsndr/cloudflare-worker-jwt": "^3.2.1",
    "cookie": "^1.1.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "djwt": "^2.0.0",
    "dotenv": "^17.4.2",
    "hono": "^4.12.12",
    "jimp": "1.6.0",
    "jsonrepair": "^3.13.3",
    "langs": "^2.0.0",
    "mariadb": "^3.5.2",
    "nanoid": "^5.1.7",
    "undici": "^8.0.2"
  },
  "devDependencies": {
    "@cloudflare/puppeteer": "^1.0.7",
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.6.0",
    "better-sqlite3": "^12.8.0",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "esbuild": "^0.28.0",
    "node-addon-api": "^8.7.0",
    "node-gyp": "^12.2.0",
    "sharp": "^0.34.5",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "wrangler": "^4.81.1"
  }
}
