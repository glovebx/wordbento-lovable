{
  "manifest_version": 3,
  "name": "Wordbento单词AI助手",
  "version": "1.0.1",
  "description": "Wordbento，英文/日文单词AI助手",
  "permissions": [
    "activeTab",
    "storage",
    "scripting",
    "contextMenus"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content.js"],
      "css": ["css/content.css"],
      "run_at": "document_start"
    }
  ],
  "background": {
    "service_worker": "src/background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Wordbento单词AI助手设置"
  },
  "web_accessible_resources": [
    {
      "resources": ["css/content.css"],
      "matches": ["<all_urls>"]
    }
  ]
}